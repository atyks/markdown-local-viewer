/**
 * markdown-local-viewer 設定ファイル (雛形)
 * 
 * このファイルを `config.js` という名前でコピーして、設定をカスタマイズしてください。
 * `config.js` は `.gitignore` に登録されているため、gitの追跡対象外となります。
 * 
 * 設定ファイルが存在しない、または一部の項目が未定義の場合は、デフォルト値が使用されます。
 */
window.markdownViewerConfig = {
  // 1. カラーリング設定（差し色を効果的に使う配色）
  // 未指定の場合はデフォルトの「ブルー ＆ オレンジアクセント」が適用されます。
  theme: {
    // --- ビューア本体（コントロールパネルなど）の配色 ---
    app: {
      primary: '#1E3A8A',       // メインカラー（ヘッダー、主要ボタンなど）
      primaryHover: '#1D4ED8',  // メインカラーのホバー時
      accent: '#F97316',        // 差し色（アクセントボタン、アクティブ状態など）
      accentHover: '#EA580C',   // 差し色のホバー時
      pageBg: '#F3F4F6',        // 画面全体の背景色
      surfaceBg: '#FFFFFF',     // パネル等の背景色
      text: '#1F2937',          // テキストの基本色
      border: '#E5E7EB',        // 境界線の色
    },

    // --- 出力されるドキュメントテーマの配色 ---
    document: {
      primary: '#2563EB',       // メインカラー（見出し、箇条書きマーカーなど）
      primarySoft: '#EFF6FF',   // メインカラーの薄い色（コールアウト背景など）
      primaryStrong: '#1D4ED8', // メインカラーの強い色（リンクなど）
      accent: '#EA580C',        // 差し色（H2の左バー、目次枠、チェックボックスなど）
      text: '#1F2937',          // 本文のテキスト色
      textSub: '#4B5563',       // 補足テキストやメタ情報の色
      border: '#E5E7EB',        // 境界線や表の罫線の色
      codeBg: '#F3F4F6',        // コードブロックの背景色
      pageBg: '#F9FAFB',        // ドキュメント背景色（印刷時は常に白）
      surfaceBg: '#FFFFFF',     // ドキュメント本体の背景色（印刷時は常に白）
    }
  },

  // 2. ロゴ画像の設定
  // local/ ディレクトリ内に画像を配置し、そのパスを指定することが可能です。
  // 指定がない（空文字または未定義の）場合は、ロゴ画像は表示されません。
  logo: {
    // 例: 'local/logo.png' などの相対パス、または 'https://...' やデータURI ('data:image/...')
    url: '',
    // 表示時の高さ（幅はアスペクト比を維持して自動調整されます）
    height: '40px',
    // 画像の代替テキスト
    alt: 'Logo'
  }
};
